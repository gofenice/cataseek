# ─── Cataseek environment configuration ─────────────────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ── Server ──
NODE_ENV=production
PORT=3000
# Public URL of the APP (login/dashboard). Used in emails and payment links.
# Production example: https://app.yourdomain.com
FRONTEND_URL=http://localhost:3000
# Hostname whose root URL redirects to the super-admin area (/admin).
# Leave empty to disable. Production example: console.yourdomain.com
SUPERADMIN_HOST=

# ── Database (MySQL) ──
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=cataseek

# ── Meilisearch ──
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=

# ── Auth ──
# Generate a long random string, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ── Admin account (used by seed-admin.ts) ──
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Email (SMTP) ──
# Any provider works (Brevo, SendGrid, Mailgun, Amazon SES, your domain SMTP).
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Cataseek" <no-reply@yourdomain.com>

# ── Invoice/company branding (can also be set in Admin → Payment Settings) ──
COMPANY_NAME=Cataseek
COMPANY_EMAIL=billing@yourdomain.com
# Optional: a hosted logo image for invoice PDFs
LOGO_URL=

# ── Razorpay ──
# Keys are managed in Admin → Payment Settings (stored in DB), so these are
# usually NOT needed here. Razorpay webhook URL to register in their dashboard:
#   https://app.yourdomain.com/api/billing/razorpay/webhook
# Events: subscription.charged, subscription.cancelled, subscription.halted, payment.failed

# ── Stripe (legacy/optional — not used by the Razorpay flow) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
